# Telegram API credentials — get from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# The channel to monitor (use @username or numeric ID)
CHANNEL_USERNAME=@CopyTradingChannel

# MT5 account credentials
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Server

# Trading settings
TOTAL_LOT=0.11        # Total lot split equally across all TPs
DEVIATION=20          # Max slippage in points
MAGIC_NUMBER=234000   # Base magic number for identifying bot trades
